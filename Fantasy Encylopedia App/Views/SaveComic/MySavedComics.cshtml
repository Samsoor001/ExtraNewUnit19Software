@model IEnumerable<Fantasy_Encylopedia_App.Models.SaveComic>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Saved Comics</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

    <div class="container">

        <h1>My Saved Comics</h1>

        <p>
            <a asp-controller="CsvImporter" asp-action="Index" class="btn btn-secondary">
                Back to Search
            </a>
        </p>

        @if (!Model.Any())
        {
            <p><i>You have not saved any comics yet.</i></p>
        }
        else
        {
            <div class="table-wrapper">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Genre</th>
                            <th>Author</th>
                            <th>ISBN</th>
                            <th>Publisher</th>
                            <th>Date</th>
                            <th>Language</th>
                            <th>Name Type</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var comic in Model)
                        {
                            <tr>
                                <td>@comic.Title</td>
                                <td>@comic.Genre</td>
                                <td>@comic.Author</td>
                                <td>@comic.ISBN</td>
                                <td>@comic.Publisher</td>
                                <td>@comic.DateOfPublication</td>
                                <td>@comic.Language</td>
                                <td>@comic.NameType</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

    </div>

</body>
</html>